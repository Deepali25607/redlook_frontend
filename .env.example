# Frontend env. Copy to .env to override defaults.
# Phase 1 (mock): set to true for offline / pre-backend demos.
# Phase 2+ (real backend): set to false and start the backend at the URL below.
VITE_USE_MOCK=false
VITE_API_BASE_URL=http://localhost:4001/api

# ============================================================
# Auth provider selector
# ============================================================
# Which auth flow the login + register pages render:
#   firebase   → Firebase Phone Auth (Google sends + verifies OTP)
#   <unset>    → legacy email/phone + password + MSG91 SMS flow
# Set to "firebase" once the Firebase project is set up + the keys
# below are filled in.
VITE_AUTH_PROVIDER=

# ============================================================
# Firebase Phone Auth (only needed when VITE_AUTH_PROVIDER=firebase)
# ============================================================
# Where to get these:
#   Firebase Console → your project → Project settings (gear icon)
#   → tab "General" → "Your apps" → web app → "SDK setup & config"
#   → choose "Config" and copy each field below.
#
# Note: these are PUBLIC by design. Firebase web API keys are gated
# by the Authorized Domains list in the console, not by secrecy.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
